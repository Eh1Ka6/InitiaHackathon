generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WagerType {
  DUEL
  POOL
}

enum WagerStatus {
  PENDING_ACCEPTANCE
  ACCEPTED
  FUNDING
  FUNDED
  PLAYING
  SETTLING
  SETTLED
  CANCELLED
  EXPIRED
}

enum DrawStatus {
  OPEN
  AWAITING_QUALIFIERS
  QUALIFIED
  RANDOMNESS_REQUESTED
  SETTLED
  CANCELLED
}

model TelegramUser {
  id             Int      @id @default(autoincrement())
  telegramId     String   @unique
  username       String?
  firstName      String
  lastName       String?
  email          String?
  walletAddress  String?
  initiaUsername String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  createdWagers Wager[]      @relation("WagerCreator")
  wagerEntries  WagerEntry[]
  drawEntries   DrawEntry[]
}

model Wager {
  id           Int         @id @default(autoincrement())
  onChainId    Int?
  type         WagerType
  status       WagerStatus @default(PENDING_ACCEPTANCE)
  description  String      @default("Stack Game")
  entryFee     String
  deadline     DateTime
  maxPlayers   Int         @default(2)
  creatorId    Int
  creator      TelegramUser @relation("WagerCreator", fields: [creatorId], references: [id])
  chatId       String
  messageId    String?
  gameSeed     String?
  txHash       String?
  settleTxHash String?
  winnerId     Int?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  entries WagerEntry[]

  @@index([chatId])
  @@index([status])
}

model WagerEntry {
  id            Int      @id @default(autoincrement())
  wagerId       Int
  wager         Wager    @relation(fields: [wagerId], references: [id])
  userId        Int
  user          TelegramUser @relation(fields: [userId], references: [id])
  side          Int      @default(0)
  depositTxHash String?
  funded        Boolean  @default(false)
  score         Int?
  playTimeMs    Int?
  playedAt      DateTime?
  payout        String?
  createdAt     DateTime @default(now())

  @@unique([wagerId, userId])
  @@index([wagerId])
}

model Draw {
  id                 Int         @id @default(autoincrement())
  onChainDrawId      String      @unique // draws[drawId] on DrawHub
  status             DrawStatus  @default(OPEN)
  entryFee           String                 // wei as string
  deadline           DateTime
  multiplierConfigId Int
  gameSeed           String?                // Stack game seed for this draw
  vrfRequestId       String?
  winnerAddress      String?
  multiplier         Int?                    // 300, 100, 50, 20, 10, or 8
  payout             String?
  txHashCreate       String?
  txHashSettle       String?
  entries            DrawEntry[]
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@index([status])
  @@index([deadline])
}

model DrawEntry {
  id            Int          @id @default(autoincrement())
  drawId        Int
  draw          Draw         @relation(fields: [drawId], references: [id])
  userId        Int
  user          TelegramUser @relation(fields: [userId], references: [id])
  walletAddress String                       // Initia wallet that deposited
  homeChainId   String                       // "137", "56", "interwoven-1" — for analytics
  depositTxHash String?
  deposited     Boolean      @default(false)
  score         Int?
  playTimeMs    Int?
  qualified     Boolean      @default(false)
  playedAt      DateTime?
  createdAt     DateTime     @default(now())

  @@unique([drawId, walletAddress])
  @@index([drawId])
}
